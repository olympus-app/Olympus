<Project Sdk="Microsoft.NET.Sdk;Olympus.Sdk">

	<!-- Project Properties -->
	<PropertyGroup Label="ProjectProperties">
		<TargetFramework>netstandard2.0</TargetFramework>
		<PackageType>Dependency</PackageType>
		<IsRoslynComponent>true</IsRoslynComponent>
		<IncludeBuildOutput>false</IncludeBuildOutput>
		<DevelopmentDependency>true</DevelopmentDependency>
		<EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
		<EnableDefaultEmbeddedResourceItems>false</EnableDefaultEmbeddedResourceItems>
		<NoWarn>$(NoWarn);CS8604;RS2000;RS2007;NU5128</NoWarn>
		<NeutralLanguage>en</NeutralLanguage>
	</PropertyGroup>

	<!-- Packages References -->
	<ItemGroup Label="PackagesReferences">
		<PackageReference Include="Microsoft.CodeAnalysis.Analyzers" PrivateAssets="all" />
		<PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" />
		<PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" PrivateAssets="all" />
		<PackageReference Include="Roslynator.Analyzers" />
		<PackageReference Include="Roslynator.CodeFixes" />
		<PackageReference Include="Roslynator.Formatting.Analyzers" />
	</ItemGroup>

	<!-- Embedded Resources -->
	<ItemGroup Label="EmbeddedResources">
		<None Include="$(OutputPath)\$(AssemblyName).dll" PackagePath="analyzers\dotnet\cs" Visible="false" Pack="true" />
		<None Include="$(OutputPath)\**\$(AssemblyName).resources.dll" PackagePath="analyzers\dotnet\cs\" Visible="false" Pack="true" />
	</ItemGroup>

	<!-- Package Usings -->
	<ItemGroup Label="PackageUsings">
		<Using Include="Microsoft.CodeAnalysis" />
		<Using Include="Microsoft.CodeAnalysis.CSharp" />
		<Using Include="Microsoft.CodeAnalysis.CSharp.Syntax" />
		<Using Include="Microsoft.CodeAnalysis.CodeActions" />
		<Using Include="Microsoft.CodeAnalysis.CodeFixes" />
		<Using Include="Microsoft.CodeAnalysis.Diagnostics" />
		<Using Include="Microsoft.CodeAnalysis.Rename" />
		<Using Include="System.Collections.Immutable" />
		<Using Include="System.Composition" />
	</ItemGroup>

</Project>