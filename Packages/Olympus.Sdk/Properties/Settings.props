<Project>

	<!-- Embedded Settings for Aspire Application Host -->
	<ItemGroup Label="EmbeddedSettings" Condition="$(IsAspireApplicationHost)=='true'">
		<EmbeddedResource Include="$(SettingsFolder)\Global.json" Link="Properties\GlobalSettings.json" LogicalName="GlobalSettings.json" CopyToOutputDirectory="Never" />
		<EmbeddedResource Include="$(SettingsFolder)\Aspire\Common.json" Link="Properties\CommonSettings.json" LogicalName="CommonSettings.json" CopyToOutputDirectory="Never" />
		<EmbeddedResource Include="$(SettingsFolder)\Aspire\Development.json" Link="Properties\DevelopmentSettings.json" LogicalName="DevelopmentSettings.json" CopyToOutputDirectory="Never" />
		<EmbeddedResource Include="$(SettingsFolder)\Aspire\Production.json" Link="Properties\ProductionSettings.json" LogicalName="ProductionSettings.json" CopyToOutputDirectory="Never" />
	</ItemGroup>

	<!-- Embedded Settings for Api Application Host -->
	<ItemGroup Label="EmbeddedSettings" Condition="$(IsApiApplicationHost)=='true'">
		<EmbeddedResource Include="$(SettingsFolder)\Global.json" Link="Properties\GlobalSettings.json" LogicalName="GlobalSettings.json" CopyToOutputDirectory="Never" />
		<EmbeddedResource Include="$(SettingsFolder)\Api\Common.json" Link="Properties\CommonSettings.json" LogicalName="CommonSettings.json" CopyToOutputDirectory="Never" />
		<EmbeddedResource Include="$(SettingsFolder)\Api\Development.json" Link="Properties\DevelopmentSettings.json" LogicalName="DevelopmentSettings.json" CopyToOutputDirectory="Never" />
		<EmbeddedResource Include="$(SettingsFolder)\Api\Production.json" Link="Properties\ProductionSettings.json" LogicalName="ProductionSettings.json" CopyToOutputDirectory="Never" />
	</ItemGroup>

	<!-- Embedded Settings for Web Application Host -->
	<ItemGroup Label="EmbeddedSettings" Condition="$(IsWebApplicationHost)=='true'">
		<EmbeddedResource Include="$(SettingsFolder)\Global.json" Link="Properties\GlobalSettings.json" LogicalName="GlobalSettings.json" CopyToOutputDirectory="Never" />
		<EmbeddedResource Include="$(SettingsFolder)\Web\Common.json" Link="Properties\CommonSettings.json" LogicalName="CommonSettings.json" CopyToOutputDirectory="Never" />
		<EmbeddedResource Include="$(SettingsFolder)\Web\Development.json" Link="Properties\DevelopmentSettings.json" LogicalName="DevelopmentSettings.json" CopyToOutputDirectory="Never" />
		<EmbeddedResource Include="$(SettingsFolder)\Web\Production.json" Link="Properties\ProductionSettings.json" LogicalName="ProductionSettings.json" CopyToOutputDirectory="Never" />
	</ItemGroup>

</Project>