<Project>

	<!-- Application Properties -->
	<PropertyGroup Label="ApplicationProperties">
		<AppName>$(SolutionName)</AppName>
		<Company>$(SolutionCustomer)</Company>
		<Product>$(SolutionTitle)</Product>
		<Authors>$(SolutionAuthors)</Authors>
		<Description>$(SolutionTitle)</Description>
		<Copyright>© $([System.DateTime]::Now.Year) - Éwerton Ferreira</Copyright>
	</PropertyGroup>

</Project>