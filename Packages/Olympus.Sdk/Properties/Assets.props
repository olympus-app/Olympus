<Project>

	<!-- Assets Properties for Web Assembly -->
	<PropertyGroup Label="AssetsProperties" Condition="$(IsWebApplicationHost)=='true'">
		<WasmFingerprintAssets>true</WasmFingerprintAssets>
	</PropertyGroup>

	<!-- Service Worker Properties -->
	<PropertyGroup Label="ServiceWorkerProperties" Condition="$(IsWebApplicationHost)=='true'">
		<ServiceWorkerEnabled>true</ServiceWorkerEnabled>
		<ServiceWorkerAssetsManifest>service-worker-assets.js</ServiceWorkerAssetsManifest>
		<ErrorOnDuplicatePublishAssets>true</ErrorOnDuplicatePublishAssets>
	</PropertyGroup>

	<!-- Service Worker Definitions -->
	<ItemGroup Label="ServiceWorkerDefinitions" Condition="$(IsWebApplicationHost)=='true'">
		<ServiceWorker Include="wwwroot\service-worker.js" PublishedContent="wwwroot\service-worker.published.js" />
	</ItemGroup>

</Project>