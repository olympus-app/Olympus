<Project>

	<!-- Version Properties -->
	<PropertyGroup Label="VersionProperties">
		<Version>0.0.0</Version>
		<BuildNumber>0</BuildNumber>
		<BuildNumberForced>0</BuildNumberForced>
	</PropertyGroup>

	<!-- Version Attributes -->
	<ItemGroup Label="VersionAttributes">
		<AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
			<_Parameter1>BuildNumber</_Parameter1>
			<_Parameter2>$(BuildNumber)</_Parameter2>
		</AssemblyAttribute>
		<AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
			<_Parameter1>BuildNumberForced</_Parameter1>
			<_Parameter2>$(BuildNumberForced)</_Parameter2>
		</AssemblyAttribute>
	</ItemGroup>

</Project>