<Project Sdk="Microsoft.NET.Sdk">

	<!-- Project Properties -->
	<PropertyGroup Label="ProjectProperties">
		<TargetFramework>netstandard2.0</TargetFramework>
		<LangVersion>latest</LangVersion>
		<PackageType>MSBuildSdk</PackageType>
		<IncludeBuildOutput>false</IncludeBuildOutput>
		<SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
	</PropertyGroup>

	<!-- Embedded Resources -->
	<ItemGroup Label="EmbeddedResources">
		<None Include="Olympus.Sdk.props" PackagePath="Sdk\Sdk.props" Pack="true" />
		<None Include="Olympus.Sdk.targets" PackagePath="Sdk\Sdk.targets" Pack="true" />
		<None Include="Properties\*.props" PackagePath="Properties\" Pack="true" />
		<None Include="Targets\*.targets" PackagePath="Targets\" Pack="true" />
		<None Include="Configuration\Olympus.globalconfig" PackagePath="Configuration" Pack="true" />
	</ItemGroup>

</Project>