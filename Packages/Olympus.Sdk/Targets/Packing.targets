<Project>

	<!-- Packing Properties for Packable Projects -->
	<PropertyGroup Label="PackingProperties" Condition="$(UsePacking)=='' Or $(UsePacking)=='true' Or $(IsPackableProject)">
		<IsPackable>true</IsPackable>
	</PropertyGroup>

	<!-- Packing Properties for Not Packable Projects -->
	<PropertyGroup Label="PackingProperties" Condition="$(UsePacking)=='false' Or !$(IsPackableProject)">
		<IsPackable>false</IsPackable>
	</PropertyGroup>

	<!-- NuGet Packing Properties -->
	<ItemGroup Label="PackingProperties" Condition="$(UsePacking)=='true' Or $(PackableProjectTypes.Contains(';$(ProjectType);'))">
		<None Include="$(ProjectProps)" Pack="true" PackagePath="build\;buildTransitive\;buildMultiTargeting\" Condition="Exists($(ProjectProps))" />
		<None Include="$(ProjectTargets)" Pack="true" PackagePath="build\;buildTransitive\;buildMultiTargeting\" Condition="Exists($(ProjectTargets))" />
	</ItemGroup>

</Project>