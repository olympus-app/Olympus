<Project>

	<!-- Localization Properties -->
	<PropertyGroup Label="LocalizationProperties">
		<InvariantTimezone>true</InvariantTimezone>
		<InvariantGlobalization>true</InvariantGlobalization>
		<SatelliteResourceLanguages>en;es;pt</SatelliteResourceLanguages>
		<SupportedCultures>en;en-US;es;es-ES;pt;pt-BR</SupportedCultures>
		<EnableDefaultEmbeddedResourceItems>false</EnableDefaultEmbeddedResourceItems>
	</PropertyGroup>

	<!-- Localization Properties Override -->
	<PropertyGroup Label="LocalizationProperties" Condition="$(UseLocalization)=='true'">
		<InvariantTimezone>false</InvariantTimezone>
		<InvariantGlobalization>false</InvariantGlobalization>
	</PropertyGroup>

	<!-- Api Localization Properties -->
	<PropertyGroup Label="LocalizationProperties" Condition="$(IsApiApplication) And $(Configuration)=='Migrations'">
		<InvariantTimezone>true</InvariantTimezone>
		<InvariantGlobalization>false</InvariantGlobalization>
		<NoWarn>$(NoWarn);CA1304;CA1305;CA1310;CA1311</NoWarn>
	</PropertyGroup>

	<!-- Web Localization Properties -->
	<PropertyGroup Label="LocalizationProperties" Condition="$(IsWebApplication)">
		<InvariantTimezone>false</InvariantTimezone>
		<InvariantGlobalization>false</InvariantGlobalization>
		<BlazorWebAssemblyLoadAllGlobalizationData>true</BlazorWebAssemblyLoadAllGlobalizationData>
	</PropertyGroup>

	<!-- Hosts and Tests Embedded Resources -->
	<ItemGroup Label="LocalizationEmbeddedResources" Condition="$(IsApplicationHost) Or $(IsTestsProject)">
		<EmbeddedResource Include="$(ProjectFolder)\Resources\*.resx">
			<LogicalName>$(AssemblyName).%(FileName).resources</LogicalName>
			<GenerateSource>false</GenerateSource>
		</EmbeddedResource>
	</ItemGroup>

	<!-- General Embedded Resources -->
	<ItemGroup Label="LocalizationEmbeddedResources" Condition="!($(IsApplicationHost) Or $(IsTestsProject))">
		<EmbeddedResource Include="$(ProjectFolder)\Resources\*.resx">
			<LogicalName>$(AssemblyName).%(FileName).resources</LogicalName>
			<CustomNamespace>$(RootNamespace.Replace('.Localization','')).Localization</CustomNamespace>
			<EmitFormatMethods>true</EmitFormatMethods>
			<GenerateSource>true</GenerateSource>
			<DefaultLang>en</DefaultLang>
		</EmbeddedResource>
	</ItemGroup>

</Project>