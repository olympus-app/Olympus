<Project>

	<!-- Assembly Properties -->
	<PropertyGroup Label="AssemblyProperties">
		<OlympusSdkAssembly>$(MSBuildThisFileDirectory)..\tasks\Olympus.Sdk.dll</OlympusSdkAssembly>
	</PropertyGroup>

	<!-- ProcessTemplate Task -->
	<UsingTask TaskName="Olympus.Sdk.Tasks.ProcessTemplate" AssemblyFile="$(OlympusSdkAssembly)" />

	<!-- GenerateIco Task -->
	<UsingTask TaskName="Olympus.Sdk.Tasks.GenerateIco" AssemblyFile="$(OlympusSdkAssembly)" />

	<!-- GeneratePng Task -->
	<UsingTask TaskName="Olympus.Sdk.Tasks.GeneratePng" AssemblyFile="$(OlympusSdkAssembly)" />

</Project>