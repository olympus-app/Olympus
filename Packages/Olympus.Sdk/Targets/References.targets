<Project>

	<!-- Project References for Core Archend Layer -->
	<ItemGroup Label="ProjectReferences" Condition="$(OlympusImplicitReferences)=='enable' And $(IsCoreModulePackage) And $(IsArchendLayer)">
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreProjectFile)" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core" />
	</ItemGroup>

	<!-- Project References for Core Backend Layer -->
	<ItemGroup Label="ProjectReferences" Condition="$(OlympusImplicitReferences)=='enable' And $(IsCoreModulePackage) And $(IsBackendLayer)">
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreProjectFile)" />
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreArchendProjectFile)" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core.Archend" />
	</ItemGroup>

	<!-- Project References for Core Frontend Layer -->
	<ItemGroup Label="ProjectReferences" Condition="$(OlympusImplicitReferences)=='enable' And $(IsCoreModulePackage) And $(IsFrontendLayer)">
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreProjectFile)" />
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreArchendProjectFile)" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core.Archend" />
	</ItemGroup>

	<!-- Project References for Regular Archend Layer -->
	<ItemGroup Label="ProjectReferences" Condition="$(OlympusImplicitReferences)=='enable' And $(IsRegularModulePackage) And $(IsArchendLayer)">
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreProjectFile)" />
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreArchendProjectFile)" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core.Archend" />
	</ItemGroup>

	<!-- Project References for Regular Backend Layer -->
	<ItemGroup Label="ProjectReferences" Condition="$(OlympusImplicitReferences)=='enable' And $(IsRegularModulePackage) And $(IsBackendLayer)">
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreProjectFile)" />
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreArchendProjectFile)" />
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreBackendProjectFile)" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core.Archend" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core.Backend" />
	</ItemGroup>

	<!-- Project References for Regular Frontend Layer -->
	<ItemGroup Label="ProjectReferences" Condition="$(OlympusImplicitReferences)=='enable' And $(IsRegularModulePackage) And $(IsFrontendLayer)">
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreProjectFile)" />
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreArchendProjectFile)" />
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreFrontendProjectFile)" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core.Archend" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core.Frontend" />
	</ItemGroup>

	<!-- Project References for Aspire Application Package -->
	<ItemGroup Label="ProjectReferences" Condition="$(OlympusImplicitReferences)=='enable' And $(IsAspireApplicationPackage)">
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreProjectFile)" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core" />
	</ItemGroup>

	<!-- Project References for Aspire Application Host -->
	<ItemGroup Label="ProjectReferences" Condition="$(OlympusImplicitReferences)=='enable' And $(IsAspireApplicationHost)">
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreProjectFile)" />
		<ProjectReference Condition="$(UseApiHosting)" Include="$(ApiHostProjectFile)" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core" />
	</ItemGroup>

	<!-- Project References for Api Application Package -->
	<ItemGroup Label="ProjectReferences" Condition="$(OlympusImplicitReferences)=='enable' And $(IsApiApplicationPackage)">
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreProjectFile)" />
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreArchendProjectFile)" />
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreBackendProjectFile)" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core.Archend" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core.Backend" />
	</ItemGroup>

	<!-- Project References for Api Application Host -->
	<ItemGroup Label="ProjectReferences" Condition="$(OlympusImplicitReferences)=='enable' And $(IsApiApplicationHost)">
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreProjectFile)" />
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreArchendProjectFile)" />
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreBackendProjectFile)" />
		<ProjectReference Condition="$(IsMainSolution)" Include="$(ApiProjectFile)" />
		<ProjectReference Condition="$(IsMainSolution)" Include="$(AspireProjectFile)" />
		<ProjectReference Condition="$(UseWebHosting)" Include="$(WebHostProjectFile)" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core.Archend" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core.Backend" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Api" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Aspire" />
	</ItemGroup>

	<!-- Project References for Web Application Package -->
	<ItemGroup Label="ProjectReferences" Condition="$(OlympusImplicitReferences)=='enable' And $(IsWebApplicationPackage)">
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreProjectFile)" />
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreArchendProjectFile)" />
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreFrontendProjectFile)" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core.Archend" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core.Frontend" />
	</ItemGroup>

	<!-- Project References for Web Application Host -->
	<ItemGroup Label="ProjectReferences" Condition="$(OlympusImplicitReferences)=='enable' And $(IsWebApplicationHost)">
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreProjectFile)" />
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreArchendProjectFile)" />
		<ProjectReference Condition="$(IsMainSolution)" Include="$(CoreFrontendProjectFile)" />
		<ProjectReference Condition="$(IsMainSolution)" Include="$(WebProjectFile)" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core.Archend" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Core.Frontend" />
		<PackageReference Condition="!$(IsMainSolution)" Include="Olympus.Web" />
	</ItemGroup>

</Project>